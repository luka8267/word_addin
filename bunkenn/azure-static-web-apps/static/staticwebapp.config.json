{
  "routes": [
    {
      "route": "/support",
      "rewrite": "/taskpane.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/support/",
      "rewrite": "/taskpane.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
